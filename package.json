{
    "name": "@rdfc/orchestrator-js",
    "version": "2.2.1",
    "main": "lib/index.js",
    "type": "module",
    "bin": {
        "rdfc": "./bin/orchestrator.js"
    },
    "scripts": {
        "build": "tspc && tsc-alias",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write .",
        "test": "npm run build && vitest run",
        "prepare": "husky"
    },
    "files": [
        "bin/**/*",
        "lib/**/*"
    ],
    "husky": {
        "hooks": {
            "pre-commit": "echo \"Husky pre-commit\""
        }
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "keywords": [],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rdf-connect/orchestrator-js.git"
    },
    "author": "Arthur Vercruysse",
    "contributors": [
        "Ieben Smessaert",
        "Julián Rojas"
    ],
    "license": "MIT",
    "description": "A JavaScript/TypeScript implementation of an RDF-based orchestrator for managing and executing data processing pipelines.",
    "devDependencies": {
        "@ajuvercr/ts-transformer-inline-file": "^0.2.0",
        "@eslint/js": "^10.0.1",
        "@rdfjs/types": "^2.0.1",
        "@types/jsonld": "^1.5.15",
        "@types/n3": "^1.26.1",
        "@types/node": "^25.9.4",
        "@typescript-eslint/eslint-plugin": "^8.62.0",
        "@typescript-eslint/parser": "^8.62.0",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.1",
        "ts-patch": "^4.0.1",
        "tsc-alias": "^1.8.17",
        "ttypescript": "^1.5.15",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.14.4",
        "@rdfc/proto": "^0.1.3",
        "@treecg/types": "^0.4.6",
        "eyeling": "^2.35.0",
        "jsonld-streaming-parser": "^5.0.1",
        "jszip": "^3.10.1",
        "n3": "^2.1.0",
        "rdf-data-factory": "^2.0.2",
        "rdf-lens": "^1.3.7",
        "rdf-serialize": "^5.1.0",
        "rdf-stores": "^2.2.0",
        "stream-to-string": "^1.2.1",
        "streamify-array": "^2.0.0",
        "winston": "^3.19.0",
        "winston-transport": "^4.9.0"
    }
}
